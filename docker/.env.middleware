# ============================================================
# Apboa 生产部署 - 中间件服务器 环境配置（.env.middleware）
# 部署位置：中间件服务器（Server 3）
# 使用方式：由用户复制为 .env 并填写实际值
# ============================================================

# ==================== MySQL 配置 ====================
MYSQL_PORT=3306
MYSQL_DATABASE=apboa_next
MYSQL_ROOT_PASSWORD=root

# ==================== Redis 配置 ====================
REDIS_PORT=6379
REDIS_PASSWORD=redis

# ==================== 向量库配置 ====================
PG_PORT=5432
PG_DATABASE=apboa_vector
PG_USER=postgres
PG_PASSWORD=postgres

# ==================== 镜像仓库配置 ====================
DOCKER_REGISTRY=

# ==================== 路径配置 ====================
# DATA_PATH=./data
