# ============================================================
# Apboa 生产部署 - 控制台节点 环境配置（.env.console）
# 部署位置：控制台服务器（Server 1）
# 使用方式：由用户复制为 .env 并填写实际值
# ============================================================

# ==================== MySQL 配置 ====================
# 指向中间件服务器（Server 3）的 IP 地址
MYSQL_HOST=192.168.1.3
MYSQL_PORT=3306
MYSQL_DATABASE=apboa_next
MYSQL_USER=root
MYSQL_PASSWORD=root

# ==================== Redis 配置 ====================
# 指向中间件服务器（Server 3）的 IP 地址
REDIS_HOST=192.168.1.3
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DATABASE=7

# ==================== 镜像仓库配置 ====================
DOCKER_REGISTRY=

# ==================== 后端配置 ====================
JWT_SECRET=ZJr8c2xF0y5b7yM+1H9v9cGZq6nZ5e0k5r3Cw7H8vJQ=
CONSOLE_MEM_LIMIT=4g
CONSOLE_CPU_LIMIT=4
CONSOLE_JAVA_HEAP_PERCENTAGE=75.0

# ==================== 前端配置 ====================
FRONTEND_PORT=80
VITE_APP_BASE_API=/web
VITE_APP_CONTEXT_PATH=/web
# 指向执行节点服务器（Server 2）的 IP 地址，Nginx upstream 使用
RUNTIME_HOST=192.168.1.2
RUNTIME_PORT=3061

# ==================== WebSocket 服务配置 ====================
# console 和 websocket 部署在同一台服务器，使用容器名互通
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=apboa-websocket
WEBSOCKET_PORT=3064
WEBSOCKET_MEM_LIMIT=1g
WEBSOCKET_CPU_LIMIT=2
WEBSOCKET_JAVA_HEAP_PERCENTAGE=50.0

# ==================== 路径配置 ====================
# DATA_PATH=./data
# LOG_PATH=./logs
