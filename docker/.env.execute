# ============================================================
# Apboa 生产部署 - 执行节点 环境配置（.env.execute）
# 部署位置：执行节点服务器（Server 2+），可多实例
# 使用方式：由 start-execute.sh 自动复制为 .env
# 注意：APBOA_NODE_ID/APBOA_HOST_NAME/APBOA_HOST_IP 由启动脚本自动注入
# ============================================================

# ==================== MySQL 配置 ====================
# 指向中间件服务器（Server 3）的 IP 地址
MYSQL_HOST=192.168.1.3
MYSQL_PORT=3306
MYSQL_DATABASE=apboa_next
MYSQL_USER=root
MYSQL_PASSWORD=root

# ==================== Redis 配置 ====================
# 指向中间件服务器（Server 3）的 IP 地址
REDIS_HOST=192.168.1.3
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DATABASE=7

# ==================== 向量库配置 ====================
VECTOR_STORE_TYPE=pgvector
# 指向中间件服务器（Server 3）的 IP 地址
PG_HOST=192.168.1.3
PG_PORT=5432
PG_DATABASE=apboa_vector
PG_USER=postgres
PG_PASSWORD=postgres

# ==================== 镜像仓库配置 ====================
DOCKER_REGISTRY=

# ==================== 后端配置 ====================
JWT_SECRET=ZJr8c2xF0y5b7yM+1H9v9cGZq6nZ5e0k5r3Cw7H8vJQ=

# 指向控制台服务器（Server 1）的 IP 地址，心跳上报使用
CONSOLE_HOST=192.168.1.1

# runtime 资源限制
RUNTIME_MEM_LIMIT=8g
RUNTIME_CPU_LIMIT=8
RUNTIME_JAVA_HEAP_PERCENTAGE=75.0
RUNTIME_PORT=3061

# Shell 执行代理配置
SHELLPROXY_MEM_LIMIT=1g
SHELLPROXY_CPU_LIMIT=2
SHELLPROXY_PIDS_LIMIT=200
SHELLPROXY_DEFAULT_TIMEOUT=300
SHELLPROXY_MAX_TIMEOUT=3600
SHELLPROXY_MAX_OUTPUT_SIZE=52428800
SHELLPROXY_JAVA_HEAP_PERCENTAGE=50.0

# 文件同步服务配置
FILE_MEM_LIMIT=512m
FILE_CPU_LIMIT=0.5
FILE_JAVA_HEAP_PERCENTAGE=60.0

# ==================== WebSocket 服务配置 ====================
# 指向控制台服务器（Server 1），websocket 与 console 部署在同一台机器
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=192.168.1.1
WEBSOCKET_PORT=3064

# ==================== Workspace 配置 ====================
WORKSPACE_CAPACITY_MB=30

# ==================== 路径配置 ====================
# DATA_PATH=./data
# LOG_PATH=./logs
